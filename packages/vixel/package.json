{
  "name": "@classytic/vixel",
  "version": "0.6.1",
  "description": "Composable FFmpeg primitives for AI/agentic video â€” typed, dry-runnable, tree-shakeable. Source, captions, profiles, and a declarative compose renderer.",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.mjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs"
    },
    "./generators": {
      "types": "./dist/generators/index.d.mts",
      "import": "./dist/generators/index.mjs"
    },
    "./utils": {
      "types": "./dist/utils/index.d.mts",
      "import": "./dist/utils/index.mjs"
    },
    "./profiles": {
      "types": "./dist/profiles/index.d.mts",
      "import": "./dist/profiles/index.mjs"
    },
    "./captions": {
      "types": "./dist/captions/index.d.mts",
      "import": "./dist/captions/index.mjs"
    },
    "./compose": {
      "types": "./dist/compose/index.d.mts",
      "import": "./dist/compose/index.mjs"
    },
    "./compositing": {
      "types": "./dist/compositing/index.d.mts",
      "import": "./dist/compositing/index.mjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md",
    "DESIGN.md"
  ],
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --project unit",
    "test:unit": "vitest run --project unit",
    "test:e2e": "vitest run --project e2e",
    "test:all": "vitest run",
    "test:watch": "vitest --project unit",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --project unit --coverage",
    "prepublishOnly": "npm run build && npm run test:unit",
    "push": "classytic-push"
  },
  "keywords": [
    "video",
    "video-processing",
    "ffmpeg",
    "hls",
    "streaming",
    "gif",
    "video-effects",
    "ai-video",
    "video-engine",
    "transcoding",
    "adaptive-bitrate",
    "thumbnails",
    "vixel"
  ],
  "author": "Classytic",
  "license": "MIT",
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/classytic/vixel"
  },
  "homepage": "https://github.com/classytic/vixel#readme",
  "bugs": {
    "url": "https://github.com/classytic/vixel/issues"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "peerDependencies": {
    "@classytic/vixel-schema": ">=0.2.0",
    "fluent-ffmpeg": ">=2.1.0"
  },
  "optionalDependencies": {
    "@resvg/resvg-js": "^2.6.2"
  },
  "devDependencies": {
    "@classytic/dev-tools": "^0.2.0",
    "@resvg/resvg-js": "^2.6.2",
    "@types/fluent-ffmpeg": "^2.1.27",
    "@types/node": "^22.10.2",
    "@vitest/ui": "^2.1.8",
    "fluent-ffmpeg": "^2.1.3",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8",
    "tsdown": "^0.22.3"
  }
}
