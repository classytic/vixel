{
  "name": "@classytic/vixel-ui",
  "version": "0.2.1",
  "description": "Headless, configurable React editor primitives for vixel. A timeline UI over the VixelSpec contract Ã¢â‚¬â€ agent-emittable, human-editable, render via @classytic/vixel.",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./editor": {
      "types": "./dist/editor/index.d.ts",
      "import": "./dist/editor/index.js"
    },
    "./timeline": {
      "types": "./dist/timeline/index.d.ts",
      "import": "./dist/timeline/index.js"
    },
    "./transport": {
      "types": "./dist/transport/index.d.ts",
      "import": "./dist/transport/index.js"
    },
    "./shared": {
      "types": "./dist/shared/index.d.ts",
      "import": "./dist/shared/index.js"
    },
    "./preview": {
      "types": "./dist/preview/index.d.ts",
      "import": "./dist/preview/index.js"
    },
    "./renderer": {
      "types": "./dist/preview/pixi/index.d.ts",
      "import": "./dist/preview/pixi/index.js"
    },
    "./export": {
      "types": "./dist/export/index.d.ts",
      "import": "./dist/export/index.js"
    },
    "./styles.css": "./styles.css",
    "./package.json": "./package.json"
  },
  "sideEffects": false,
  "files": [
    "dist",
    "styles.css",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsdown && tsc --emitDeclarationOnly --outDir dist",
    "dev": "tsdown --watch",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "react",
    "video-editor",
    "timeline",
    "headless",
    "vixel",
    "video",
    "ffmpeg",
    "ai-video",
    "agentic",
    "typescript"
  ],
  "author": "Classytic",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "peerDependencies": {
    "@classytic/vixel-schema": ">=0.2.0",
    "react": ">=19.0.0",
    "react-dom": ">=19.0.0"
  },
  "peerDependenciesMeta": {
    "react-dom": {
      "optional": true
    }
  },
  "dependencies": {
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.0.0",
    "tailwind-merge": ">=2.0.0"
  },
  "optionalDependencies": {
    "gifenc": "^1.0.3",
    "mp4-muxer": ">=5.0.0",
    "pixi.js": "^8.0.0"
  },
  "devDependencies": {
    "@classytic/vixel-schema": ">=0.2.0",
    "@testing-library/jest-dom": "^6.1.5",
    "@testing-library/react": "^16.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.2.0",
    "@vitest/coverage-v8": "^4.0.0",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.0.0",
    "gifenc": "^1.0.3",
    "happy-dom": "^20.0.0",
    "mp4-muxer": ">=5.0.0",
    "pixi.js": "^8.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwind-merge": "^2.0.0",
    "tsdown": "^0.22.3",
    "typescript": "^5.3.0",
    "vitest": "^4.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/classytic/vixel-ui.git"
  },
  "homepage": "https://github.com/classytic/vixel-ui#readme",
  "bugs": {
    "url": "https://github.com/classytic/vixel-ui/issues"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
