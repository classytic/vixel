{
  "name": "@classytic/vixel-schema",
  "version": "0.5.2",
  "description": "The VixelSpec composition contract â€” zero-dependency, agent-emittable TypeScript types shared by vixel (engine), vixel-ui (editor), and agents. No ffmpeg, no React.",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./validate": {
      "types": "./dist/validate.d.ts",
      "import": "./dist/validate.js"
    },
    "./isf": {
      "types": "./dist/isf.d.ts",
      "import": "./dist/isf.js"
    },
    "./package.json": "./package.json"
  },
  "sideEffects": false,
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsdown && tsc --emitDeclarationOnly --outDir dist",
    "dev": "tsdown --watch",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "push": "classytic-push",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "vixel",
    "video",
    "schema",
    "composition",
    "ai-video",
    "agentic",
    "typescript",
    "types"
  ],
  "author": "Classytic",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/classytic/vixel-schema.git"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "peerDependencies": {
    "zod": ">=4.0.0"
  },
  "peerDependenciesMeta": {
    "zod": {
      "optional": true
    }
  },
  "devDependencies": {
    "@classytic/dev-tools": "^0.2.0",
    "tsdown": "^0.22.3",
    "typescript": "^5.3.0",
    "vitest": "^4.0.0",
    "zod": "^4.0.0"
  }
}
