{
  "name": "@classytic/vixel",
  "version": "0.1.0",
  "description": "Video processing engine - HLS streaming, effects, transformations. Minimal, extensible, future-proof.",
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./generators": {
      "types": "./dist/generators/index.d.ts",
      "import": "./dist/generators/index.js"
    },
    "./utils": {
      "types": "./dist/utils/index.d.ts",
      "import": "./dist/utils/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "video",
    "video-processing",
    "ffmpeg",
    "hls",
    "streaming",
    "gif",
    "video-effects",
    "ai-video",
    "video-engine",
    "transcoding",
    "adaptive-bitrate",
    "thumbnails",
    "vixel"
  ],
  "author": "Classytic",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/classytic/vixel"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "peerDependencies": {
    "fluent-ffmpeg": "^2.1.0"
  },
  "devDependencies": {
    "@types/fluent-ffmpeg": "^2.1.27",
    "@types/node": "^22.10.2",
    "@vitest/ui": "^2.1.8",
    "fluent-ffmpeg": "^2.1.3",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}